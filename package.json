{
  "name": "ccsniff",
  "version": "1.0.22",
  "description": "Watch Claude Code JSONL output files and emit structured events as a Node.js EventEmitter",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.cjs"
    }
  },
  "bin": {
    "ccsniff": "./src/cli.js"
  },
  "files": [
    "src/"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agent",
    "watch",
    "streaming",
    "jsonl"
  ],
  "author": "lanmower",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnEntrypoint/ccsniff.git"
  },
  "homepage": "https://anentrypoint.github.io/ccsniff",
  "engines": {
    "node": ">=18"
  }
}
